# Smart Bookmark Manager - Environment Variables
# Copy this file to .env and fill in the values

# ===========================================
# JWT Secret (change this in production!)
# ===========================================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this

# ===========================================
# Qwen Code API (qwen-code-api proxy)
# ===========================================
# Qwen Code API proxies OpenAI-compatible requests to the Qwen LLM service.
# It handles authentication via ~/.qwen/oauth_creds.json (OAuth with Qwen).

# Qwen Code API container settings
QWEN_CODE_API_CONTAINER_ADDRESS=0.0.0.0
QWEN_CODE_API_CONTAINER_PORT=8080
QWEN_CODE_API_HOST_ADDRESS=127.0.0.1
QWEN_CODE_API_HOST_PORT=8080

# Model to use (available via qwen-code-api)
QWEN_CODE_API_MODEL=qwen-plus

# Logging: off, error, debug
QWEN_CODE_API_LOG_LEVEL=error

# Retry configuration
QWEN_CODE_API_MAX_RETRIES=5
QWEN_CODE_API_RETRY_DELAY_MS=1000

# Use ~/.qwen/oauth_creds.json for Qwen authentication
# Set to true to use mounted OAuth credentials, false to disable
QWEN_CODE_API_AUTH_USE=true

# Log incoming requests (useful for debugging)
QWEN_CODE_API_LOG_REQUESTS=true

# API Key (optional - adds API key validation on the proxy layer)
# Leave empty to disable API key auth on qwen-code-api
QWEN_CODE_API_KEY=

# Docker registry prefix (use harbor.pg.innopolis.university/docker-hub-cache/ for university VMs)
REGISTRY_PREFIX_DOCKER_HUB=

# ===========================================
# Service Ports
# ===========================================
POSTGRES_HOST_PORT=5432
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=80

# ===========================================
# CORS Origins (comma-separated)
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:80
